{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Go-Live Readiness Report",
  "description": "Structured result of the full go-live readiness audit for a ConversionOS tenant.",
  "type": "object",
  "required": ["site_id", "date", "verdict", "checks", "human_review_required"],
  "properties": {
    "site_id": {
      "type": "string",
      "description": "Tenant site ID"
    },
    "date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the audit"
    },
    "verdict": {
      "type": "string",
      "enum": ["READY", "REVIEW", "NOT READY"],
      "description": "Overall go-live readiness verdict"
    },
    "critical_failures": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of critical failures that block go-live"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of warnings that merit review but don't block go-live"
    },
    "checks": {
      "type": "object",
      "description": "Per-check results",
      "properties": {
        "content_integrity": {
          "type": ["object", "null"],
          "properties": {
            "passed": { "type": "boolean" },
            "violations": { "type": "integer", "minimum": 0 }
          }
        },
        "visual_qa": {
          "type": ["object", "null"],
          "properties": {
            "passed": { "type": "boolean" },
            "average": { "type": "number", "minimum": 0, "maximum": 5 }
          }
        },
        "live_site_audit": {
          "type": ["object", "null"],
          "properties": {
            "passed": { "type": "boolean" },
            "checks_passed": { "type": "integer", "minimum": 0 },
            "checks_run": { "type": "integer", "minimum": 0 }
          }
        },
        "original_vs_demo": {
          "type": ["object", "null"],
          "properties": {
            "passed": { "type": "boolean" },
            "match_score": { "type": "integer", "minimum": 0, "maximum": 100 }
          }
        },
        "pdf_branding": {
          "type": ["object", "null"],
          "properties": {
            "passed": { "type": "boolean" },
            "critical": { "type": "integer", "minimum": 0 }
          }
        },
        "email_branding": {
          "type": ["object", "null"],
          "properties": {
            "passed": { "type": "boolean" },
            "critical": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "human_review_required": {
      "type": "boolean",
      "description": "Always true — human review is mandatory before go-live"
    }
  }
}
