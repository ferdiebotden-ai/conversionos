{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["pages", "theme"],
  "properties": {
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "title", "sections"],
        "properties": {
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "sections": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sectionId"],
              "properties": {
                "sectionId": { "type": "string", "pattern": "^[a-z]+:[a-z0-9-]+$" },
                "customRequired": { "type": "boolean", "default": false },
                "customSpec": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "theme": {
      "type": "object",
      "properties": {
        "colors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "accent": { "type": "string" }
          },
          "additionalProperties": false
        },
        "typography": {
          "type": "object",
          "properties": {
            "headingFont": { "type": "string" },
            "bodyFont": { "type": "string" }
          },
          "additionalProperties": false
        },
        "borderRadius": { "type": "string" },
        "spacing": { "type": "string", "enum": ["compact", "default", "spacious"] },
        "animationPreset": { "type": "string", "enum": ["fade-in-up", "stagger-reveal", "slide-in-left", "none"] }
      },
      "additionalProperties": false
    },
    "customSections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "sectionId", "spec"],
        "properties": {
          "name": { "type": "string" },
          "sectionId": { "type": "string" },
          "spec": { "type": "string" },
          "dataSource": { "type": "string" },
          "referenceSection": { "type": "string" }
        },
        "additionalProperties": false
      },
      "maxItems": 5
    },
    "contentElevation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "current", "suggested", "reason"],
        "properties": {
          "field": { "type": "string" },
          "current": { "type": "string" },
          "suggested": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
