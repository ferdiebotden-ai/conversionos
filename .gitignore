# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/tenant-builder/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/testing/node_modules
/testing/reports
/testing/scripts/.playwright-mcp
/testing/scripts/screenshots
/testing/scripts/logs
/testing/scripts/*.png

# supabase
supabase/.temp/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.playwright-mcp/

# session artifacts
playwright-report/

# plan files
~/.claude/plans/

# codex polish (dumped tenant state; patches in codex-polish/patches/ have their own .gitignore)
codex-polish/current-tenant.json
