{
  "type": "object",
  "properties": {
    "pass": {
      "type": "boolean",
      "description": "Whether the artifacts pass quality review (score >= 80, zero critical issues)"
    },
    "score": {
      "type": "number",
      "description": "Quality score from 0 to 100"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "minor"]
          },
          "description": {
            "type": "string"
          }
        },
        "required": ["severity", "description"]
      }
    },
    "summary": {
      "type": "string",
      "description": "Brief summary of the review"
    }
  },
  "required": ["pass", "score", "issues", "summary"]
}
