# ConversionOS Demo — Environment Variables
# Copy to .env.local and fill in values

# Multi-Tenancy (required)
NEXT_PUBLIC_SITE_ID=demo

# Supabase - Database & Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Services
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Email
RESEND_API_KEY=

# ElevenLabs Conversational AI (Voice agent — single Emma persona)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_EMMA=

# Demo mode (shows Admin link in header)
NEXT_PUBLIC_DEMO_MODE=true

# Analytics (optional)
VERCEL_ANALYTICS_ID=
